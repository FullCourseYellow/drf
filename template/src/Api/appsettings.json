{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=app.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Oidc": {
    "Authority": "https://your-oidc-provider.example.com",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret"
  }
}
